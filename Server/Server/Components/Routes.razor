<Router AppAssembly="typeof(Program).Assembly"
        AdditionalAssemblies="new[] { typeof(Schuldenbuch.Components.Dashboard).Assembly }">
    <Found Context="routeData">
        <RouteView RouteData="routeData" DefaultLayout="typeof(Server.Components.Layout.MainLayout)" />
        <FocusOnNavigate RouteData="routeData" Selector="h1" />
    </Found>
    <NotFound>
        <LayoutView Layout="typeof(Server.Components.Layout.MainLayout)">
            <p role="alert">Seite nicht gefunden.</p>
        </LayoutView>
    </NotFound>
</Router>

